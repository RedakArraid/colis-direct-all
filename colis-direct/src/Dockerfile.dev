FROM node:18-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache bash

# Copy package files first for better caching
COPY package*.json ./

# Install ALL dependencies (including devDependencies for Vite dev server)
RUN npm ci --legacy-peer-deps --include=dev || npm install --legacy-peer-deps

# Copy config files into the image to avoid macOS VirtioFS -35 errors
# (individual file bind mounts on macOS Docker Desktop cause EAGAIN/-35)
COPY vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json ./
COPY tailwind.config.js postcss.config.js eslint.config.js ./
COPY index.html ./

# Expose port
EXPOSE 5173

# Note: src/ et public/ seront montés via volume dans docker-compose.dev.yml
CMD ["npm", "run", "dev", "--", "--host"]

