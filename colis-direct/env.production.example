# =============================================================================
# COLIS DIRECT - Variables d'environnement Production
# =============================================================================
# Copiez ce fichier vers .env.production et remplissez les valeurs
# cp env.production.example .env.production
# NE JAMAIS commiter .env.production dans git
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
COLISDIRECT_DB_NAME=colisdirect_db
COLISDIRECT_DB_USER=colisdirect
COLISDIRECT_DB_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_EN_PRODUCTION

# -----------------------------------------------------------------------------
# JWT (Authentification)
# Générez un secret fort : openssl rand -base64 64
# -----------------------------------------------------------------------------
COLISDIRECT_JWT_SECRET=CHANGEZ_CE_SECRET_JWT_EN_PRODUCTION
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Paystack (paiement principal — Mobile Money + Carte)
# Récupérer sur https://dashboard.paystack.com/#/settings/developer
# Webhook à enregistrer : https://api.colisdirect.com/api/payments/paystack/webhook
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE_PAYSTACK

# -----------------------------------------------------------------------------
# CinetPay (backup Mobile Money CI)
# Récupérer sur https://cinetpay.com
# -----------------------------------------------------------------------------
CINETPAY_API_KEY=VOTRE_CLE_API_CINETPAY
CINETPAY_SITE_ID=VOTRE_SITE_ID_CINETPAY

# -----------------------------------------------------------------------------
# SMTP (emails transactionnels — confirmations, notifications)
# Utiliser un mot de passe d'application Gmail (pas le mot de passe du compte)
# https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact.colisdirect@gmail.com
SMTP_PASS=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
# Le backend nodemailer lit SMTP_PASSWORD (recommandé) :
SMTP_PASSWORD=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
EMAIL_FROM=contact.colisdirect@gmail.com
EMAILS_FROM_EMAIL=contact.colisdirect@gmail.com

# -----------------------------------------------------------------------------
# URLs publiques (optionnel si déjà dans docker-compose.prod.yml)
# -----------------------------------------------------------------------------
# FRONTEND_URL=https://colisdirect.com
# BACKEND_URL=https://api.colisdirect.com

# -----------------------------------------------------------------------------
# Frontend (URL de l'API au moment du build Docker)
# -----------------------------------------------------------------------------
VITE_API_URL=https://api.colisdirect.com/api
