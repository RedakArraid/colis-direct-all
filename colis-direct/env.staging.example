# =============================================================================
# COLIS DIRECT - Variables d'environnement Staging
# =============================================================================
# Copiez ce fichier vers .env.staging et remplissez les valeurs
# cp env.staging.example .env.staging
# NE JAMAIS commiter .env.staging dans git
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL (staging isolé de la prod)
# -----------------------------------------------------------------------------
COLISDIRECT_STAGING_DB_NAME=colisdirect_staging_db
COLISDIRECT_STAGING_DB_USER=colisdirect_staging
COLISDIRECT_STAGING_DB_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_STAGING

# -----------------------------------------------------------------------------
# JWT (Authentification)
# Générez un secret fort : openssl rand -base64 64
# Utilisez un secret DIFFÉRENT de la prod
# -----------------------------------------------------------------------------
COLISDIRECT_JWT_SECRET=CHANGEZ_CE_SECRET_JWT_STAGING
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Paystack (paiement — utilisez les clés TEST pour le staging)
# Récupérer sur https://dashboard.paystack.com/#/settings/developer
# Webhook à enregistrer : https://staging-api.colisdirect.com/api/payments/paystack/webhook
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_VOTRE_CLE_TEST_PAYSTACK

# -----------------------------------------------------------------------------
# CinetPay (backup Mobile Money — mode test)
# Récupérer sur https://cinetpay.com
# -----------------------------------------------------------------------------
CINETPAY_API_KEY=VOTRE_CLE_API_CINETPAY_TEST
CINETPAY_SITE_ID=VOTRE_SITE_ID_CINETPAY_TEST

# -----------------------------------------------------------------------------
# SMTP (emails transactionnels)
# Peut pointer vers une boîte de test (ex: Mailtrap, Mailpit)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact.colisdirect@gmail.com
SMTP_PASS=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
# Optionnel : si défini, pris en priorité par nodemailer ; sinon SMTP_PASS est utilisé (voir emailService)
# SMTP_PASSWORD=
EMAIL_FROM=contact.colisdirect@gmail.com

# -----------------------------------------------------------------------------
# Frontend (URL de l'API appelée par le navigateur)
# -----------------------------------------------------------------------------
VITE_STAGING_API_URL=https://staging-api.colisdirect.com/api
