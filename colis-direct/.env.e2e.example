# Copie ce fichier vers .env.e2e.local et renseigne uniquement les comptes utiles.
# .env.e2e.local est ignore par Git.

E2E_BASE_URL=https://staging.colisdirect.com
E2E_API_ORIGIN=https://staging-api.colisdirect.com
E2E_API_URL=https://staging-api.colisdirect.com/api

# Le staging frontend a parfois un certificat temporaire Traefik.
# Les tests navigateur ignorent ce blocage, mais un test infra strict le signale.
E2E_IGNORE_HTTPS_ERRORS=true
E2E_CHECK_FRONTEND_TLS=false

# api = utilise /auth/signin (cache global-setup) ; jwt = token local sans signin.
E2E_AUTH_MODE=api
E2E_JWT_SECRET=

# Optionnel : cle partagee avec E2E_RATE_LIMIT_BYPASS_KEY sur staging-api (evite 429).
E2E_RATE_LIMIT_BYPASS_KEY=

# Comptes dedies au staging pour les parcours connectes.
# Les emails ci-dessous sont les comptes E2E reserves.
# Renseigner les mots de passe uniquement dans .env.e2e.local.
E2E_CLIENT_EMAIL=e2e+client@colisdirect.test
E2E_CLIENT_USER_ID=
E2E_CLIENT_PASSWORD=

E2E_ADMIN_EMAIL=e2e+admin@colisdirect.test
E2E_ADMIN_USER_ID=bffd19dd-783f-44d1-9a7c-723a450e47d2
E2E_ADMIN_PASSWORD=

E2E_RELAY_EMAIL=e2e+relay@colisdirect.test
E2E_RELAY_USER_ID=
E2E_RELAY_PASSWORD=

E2E_TRANSPORTER_EMAIL=e2e+transporter@colisdirect.test
E2E_TRANSPORTER_USER_ID=
E2E_TRANSPORTER_PASSWORD=

E2E_SUPPORT_EMAIL=e2e+support@colisdirect.test
E2E_SUPPORT_USER_ID=257658a1-ee1-413-aa92-7a04e9f3f123
E2E_SUPPORT_PASSWORD=

# Optionnel : numero connu pour tester le suivi public.
E2E_KNOWN_TRACKING_NUMBER=
