{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile": "VITE_API_URL=https://staging-api.colisdirect.com/api vite build",
    "build:mobile:staging": "VITE_API_URL=https://staging-api.colisdirect.com/api vite build",
    "build:mobile:ios-local": "VITE_API_URL=http://localhost:3001/api vite build",
    "cap:sync": "npm run build:mobile && cap sync ios",
    "cap:sync:staging": "npm run build:mobile:staging && cap sync ios",
    "cap:sync:ios-local": "npm run build:mobile:ios-local && cap sync ios",
    "cap:open:ios": "cap open ios",
    "cap:run:ios": "npm run build:mobile && cap run ios",
    "android:build": "cd android && ./scripts/build-dev.sh",
    "android:install": "cd android && chmod +x scripts/*.sh && ./scripts/install-dev.sh",
    "android:clean-emulator": "cd android && chmod +x scripts/*.sh && ./scripts/clean-emulator.sh",
    "android:open": "open -a 'Android Studio' android",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test:e2e:install": "playwright install chromium chromium-headless-shell",
    "test:e2e:dispatch": "playwright test tests/e2e/specs/home-pickup-dispatch.spec.ts --grep API",
    "test:api:home-pickup": "node scripts/test-home-pickup-api.mjs",
    "test:e2e:staging": "playwright test; STATUS=$?; node scripts/e2e-summary.mjs; exit $STATUS",
    "test:e2e:headed": "playwright test --headed; STATUS=$?; node scripts/e2e-summary.mjs; exit $STATUS",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:summary": "node scripts/e2e-summary.mjs",
    "tw:watch": "tailwindcss -i src/index.css -o src/tailwind-output.css --watch",
    "tw:build": "tailwindcss -i src/index.css -o src/tailwind-output.css"
  },
  "dependencies": {
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.6.5",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.0",
    "react-leaflet": "^4.2.1",
    "react-toastify": "^10.0.6",
    "recharts": "^3.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
