# Copier vers local.properties (fichier gitignoré) et adapter.
# Gradle lit ce fichier pour le SDK et l’URL API du flavor dev.

sdk.dir=/chemin/vers/Android/sdk

# Si `./gradlew` affiche « Unable to locate a Java Runtime » (terminal sans JAVA_HOME) :
# java.home=/Applications/Android Studio.app/Contents/jbr/Contents/Home

# ── Flavor dev (APK ci.colisdirect.app.dev) ─────────────────────────────────
# Par défaut si absent : https://staging-api.colisdirect.com/api/
# (même API / BDD que les comptes E2E e2e+*@colisdirect.test)

# Staging explicite (optionnel, identique au défaut) :
# dev.api.base.url=https://staging-api.colisdirect.com/api/

# Backend local sur la machine hôte — émulateur Android :
# dev.api.base.url=http://10.0.2.2:3001/api/

# Backend local — téléphone physique (remplacer par l’IP du Mac sur le LAN) :
# dev.api.base.url=http://192.168.1.10:3001/api/

# ── Signature release (flavor prod, AAB Play Store) ─────────────────────────
# storeFile=/chemin/vers/colisdirect-release.keystore
# storePassword=***
# keyAlias=colisdirect
# keyPassword=***
